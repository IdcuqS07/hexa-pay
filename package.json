{
  "name": "hexapay-fhenix",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "smoke:private-quotes:service": "node scripts/private-quotes/smoke-service.cjs",
    "smoke:private-quotes:api": "node scripts/private-quotes/smoke-api-adapter.mjs",
    "verify:private-quotes": "npm run smoke:private-quotes:service && npm run smoke:private-quotes:api",
    "demo:private-quotes:paths": "node scripts/private-quotes/demo-paths.cjs",
    "demo:private-quotes:challenges": "node scripts/private-quotes/demo-challenge-lifecycle.cjs",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy.js --network arb-sepolia",
    "deploy:token": "hardhat run scripts/deploy-token.js --network arb-sepolia",
    "bootstrap-wrap": "hardhat run scripts/bootstrap-wrap.js --network arb-sepolia",
    "bootstrap-unwrap": "hardhat run scripts/bootstrap-unwrap.js --network arb-sepolia",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "node": "hardhat node",
    "setup-wallet": "node scripts/setup-wallet.js",
    "check-balance": "hardhat run scripts/check-balance.js --network arb-sepolia",
    "interact": "hardhat run scripts/interact.js --network arb-sepolia",
    "forge:build": "forge build",
    "forge:test": "forge test -vv",
    "forge:test:bootstrap": "forge test --match-contract PrivateMerchantQuoteBootstrapTest -vv",
    "forge:test:min": "forge test --match-test 'test_CreateQuote_Success|test_GrantAccess_Success|test_SettleQuote_Success|test_SettleQuote_RevertWhenWrongPayer' -vv",
    "forge:test:cofhe": "forge test --match-contract PrivateMerchantQuoteCofheTest -vv",
    "forge:test:mock": "forge test --match-contract PrivateMerchantQuoteFoundryTest -vv",
    "forge:deploy": "forge script script/Deploy.s.sol:DeployPrivateMerchantQuote --rpc-url local --broadcast",
    "forge:deploy:cofhe": "forge script script/DeployCofhe.s.sol:Deploy --rpc-url local --broadcast",
    "setup:deploy": "bash scripts/setup-deployment-env.sh",
    "deploy:executor": "npx hardhat run scripts/deploy-hexa-executor-safe.js --network arbitrumSepolia",
    "deploy:sepolia": "npm run setup:deploy && npm run deploy:executor",
    "test:payment-flow": "node scripts/test-payment-intent-flow.mjs"
  },
  "dependencies": {
    "@cofhe/sdk": "^0.4.0",
    "ethers": "^6.16.0",
    "gsap": "^3.12.5",
    "ioredis": "^5.10.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "viem": "^2.48.1"
  },
  "devDependencies": {
    "@cofhe/foundry-plugin": "latest",
    "@cofhe/mock-contracts": "latest",
    "@fhenixprotocol/cofhe-contracts": "^0.0.13",
    "@fhenixprotocol/cofhe-mock-contracts": "^0.3.1",
    "@fhenixprotocol/contracts": "^0.3.1",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "5.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "cofhe-hardhat-plugin": "^0.3.1",
    "cofhejs": "^0.3.1",
    "dotenv": "^16.3.1",
    "hardhat": "^2.28.6",
    "vite": "^5.2.0"
  }
}
